<launch>
  <arg  name="model" />
  <arg  name="gui"    default="true" />
  <param  name="robot_description"  textfile="$(find nanorobot_description)/urdf/robot_description.urdf" />

  <node name="joint_state_publisher"      pkg="joint_state_publisher"      type="joint_state_publisher" />
  <node name="robot_state_publisher"      pkg="robot_state_publisher"      type="robot_state_publisher" />
  <node name="joint_state_publisher_gui"  pkg="joint_state_publisher_gui"  type="joint_state_publisher_gui" if="$(arg gui)"/>
  
  <node name="rviz"  pkg="rviz"  type="rviz"  args="-d $(find nanorobot_description)/urdf.rviz" />
</launch>